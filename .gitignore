target/

# backup files generated by rustfmt
**/*.rs.bk

# editor config files and directories
*.iml
/.idea/
/.vscode/

# Python bytecode cache
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error-log*

# Build outputs
dist/
*.js.map
*.d.ts.map
.cache/

# npm package sources: track package.json + .ts, ignore built dist/
!packages/npm/**/package.json
!packages/npm/**/src/*.ts

# Static assets policy: ignore public folders and compiled CSS, keep SCSS in git
**/public/
*.css
!*.scss

# IDE / OS
.DS_Store
Thumbs.db

# MCP server configs (local tooling)
.mcp.json
.playwright-mcp/

# Keep package.json files for npm workspace management
!package.json
!packages/npm/*/package.json

# Debug JS injection scripts (intermediate artifacts, embedded as Rust strings)
packages/packager/src/debug/*.js

# W3C WebIDL cache (downloaded by fetch_w3c_idl.py)
scripts/idl-cache/

# Test artifacts
screenshot-test.png
HIKARI_BROWSER_ISSUE.md

# WIT composed copy (generated by sync-wit.sh before publish)
# Note: This directory must exist for sync-wit-check to work.
# Run `just sync-wit` to populate it from browser-worlds.
# packages/web/wit/

# Package manager lock files (not tracked per project convention)
Cargo.lock
package-lock.json
pnpm-lock.yaml

# celestia-devtools: staged-on-demand shared justfile recipes (just fetch)
/.just/
/celestia-devtools.just
.cargo/config.toml
